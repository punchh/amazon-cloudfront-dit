{
  "name": "utility-lambda",
  "scripts": {
    "test": "jest --coverage",
    "build": "tsc"
  },
  "dependencies": {
    "@airbrake/node": "^2.1.9",
    "@aws-sdk/client-ecs": "^3.993.0",
    "@aws-sdk/client-cloudwatch": "^3.993.0",
    "@types/aws-lambda": "^8.10.0",
    "newrelic": "^14.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "coverageReporters": [
      "text",
      [
        "lcov",
        {
          "projectRoot": "../"
        }
      ]
    ]
  },
  "overrides": {
    "minimatch@3": "3.1.5",
    "brace-expansion@1": "1.1.13",
    "handlebars": "4.7.9",
    "picomatch@2": "2.3.2",
    "picomatch@4": "4.0.4"
  }
}
